# TelStorage Environment Variables (Example Template)
# Copy this file to '.env' and fill in your actual credentials.

# Google Apps Script Web App URL (from Google Apps Script deployment)
SCRIPT_URL=https://script.google.com/macros/s/YOUR_APPS_SCRIPT_DEPLOYMENT_ID/exec

# Cloudflare Workers CORS Proxy URL (from Wrangler deployment)
WORKER_URL=https://YOUR_WORKER_SUBDOMAIN.workers.dev
